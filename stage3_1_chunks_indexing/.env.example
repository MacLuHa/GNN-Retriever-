# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CHUNKS_TOPIC=documents.chunks
KAFKA_VECTORIZE_TOPIC=documents.vectorize
KAFKA_CONSUMER_GROUP=chunk-indexer
KAFKA_AUTO_OFFSET_RESET=earliest

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=legal_chunks

# Logging
LOG_LEVEL=INFO
