# Logging
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CHUNKS_TOPIC=documents.chunks

# Chunking
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# Input source: Hugging Face dataset only
HF_DATASET_NAME=wikimedia/wikipedia
HF_DATASET_CONFIG_NAME=20231101.en
HF_DATASET_SPLIT=train[:1%]
HF_DATASET_STREAMING=false
HF_LIMIT=

# Field mapping from HF dataset row -> ingestion payload
HF_DOC_ID_FIELD=id
HF_VERSION_ID_FIELD=version_id
HF_TITLE_FIELD=title
HF_SOURCE_TYPE_FIELD=source_type
HF_CONTENT_BASE64_FIELD=content_base64
HF_TEXT_FIELD=text
HF_METADATA_FIELD=metadata
