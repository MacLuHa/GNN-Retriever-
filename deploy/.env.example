OPENWEBUI_PORT=3000
OPENWEBUI_PIPELINES_PORT=9099
OPENWEBUI_PIPELINES_API_KEY=pipelines-local-key
RETRIEVER_API_PORT=8010
RETRIEVER_API_URL=http://retriever-api:8010
OLLAMA_BASE_URL=http://host.docker.internal:11434

ELASTICSEARCH_URL=http://host.docker.internal:9200
ELASTICSEARCH_INDEX=legal_chunks
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=legal_chunks_vectors
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

OLLAMA_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SEC=30
OLLAMA_MAX_ATTEMPTS=3
EMBEDDING_DIM=256

RETRIEVER_TOP_K=5
BM25_TOP_K=30
GNN_TOP_K=30
BM25_WEIGHT=0.5
GNN_WEIGHT=0.5
MIN_SCORE_THRESHOLD=0.0

GNN_MODEL_PATH=stage7_1_retriever/gnn_weights.json
GNN_HOPS=2
GNN_BATCH_SIZE=64
LOG_LEVEL=INFO

RETRIEVER_RETRIEVE_TIMEOUT_SEC=20
RETRIEVER_MAX_CONTEXT_CHARS=1200
RETRIEVER_API_LOG_LEVEL=INFO
RETRIEVER_TIMEOUT_SEC=10
RETRIEVER_MAX_CONTEXT_CHUNKS=5

RERANK_ENABLED=false
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANK_TOP_N=30
RERANK_BATCH_SIZE=8
RERANK_TIMEOUT_SEC=15
RERANK_MAX_LENGTH=512
RERANK_DEVICE=auto
