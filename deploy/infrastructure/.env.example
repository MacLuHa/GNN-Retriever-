# Neo4j
NEO4J_IMAGE=neo4j:5
NEO4J_CONTAINER_NAME=neo4j

NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

NEO4J_DEFAULT_USER=neo4j
NEO4J_DEFAULT_PASSWORD=password


NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=512M

# Kafka (EXTERNAL и INTERNAL должны быть разными портами внутри контейнера)
KAFKA_IMAGE=apache/kafka:3.7.0
KAFKA_CONTAINER_NAME=kafka

KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=9093
KAFKA_CONTROLLER_PORT=9094

KAFKA_NODE_ID=0
KAFKA_CLUSTER_ID=MyClusterId1234567890

# Хост с хост-машины: localhost. Между контейнерами: имя сервиса kafka.
KAFKA_EXTERNAL_HOST=localhost
KAFKA_INTERNAL_HOST=kafka

# Kafka UI
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_CONTAINER_NAME=kafka-ui
KAFKA_UI_PORT=8080
KAFKA_UI_USERNAME=admin
KAFKA_UI_PASSWORD=admin123