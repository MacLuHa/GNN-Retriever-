# Elasticsearch (сервис elasticsearch в docker-compose.yml)
ES_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.15.0
ES_CONTAINER_NAME=elasticsearch
ES_PORT=9200
ES_TRANSPORT_PORT=9300
ES_HEAP_SIZE=512m
ES_DISCOVERY_TYPE=single-node
ES_XPACK_SECURITY_ENABLED=false
ES_XPACK_SECURITY_ENROLLMENT_ENABLED=false
ES_XPACK_SECURITY_HTTP_SSL_ENABLED=false
ES_XPACK_SECURITY_TRANSPORT_SSL_ENABLED=false

# Neo4j
NEO4J_IMAGE=neo4j:5
NEO4J_CONTAINER_NAME=neo4j

NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

NEO4J_DEFAULT_USER=neo4j
NEO4J_DEFAULT_PASSWORD=password

NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=512M

# Kafka — KRaft, два listener’а: EXTERNAL (клиенты с хоста / host.docker.internal) и INTERNAL (сеть Docker)
KAFKA_IMAGE=apache/kafka:3.7.0
KAFKA_CONTAINER_NAME=kafka

KAFKA_NODE_ID=0
KAFKA_CLUSTER_ID=MyClusterId1234567890
KAFKA_CONTROLLER_PORT=9094

# EXTERNAL: KAFKA_LISTENERS EXTERNAL://0.0.0.0:${KAFKA_EXTERNAL_PORT}
# Публикуется на хост как ${KAFKA_EXTERNAL_PORT}:${KAFKA_EXTERNAL_PORT}.
# KAFKA_ADVERTISED_LISTENERS EXTERNAL://${KAFKA_EXTERNAL_HOST}:${KAFKA_EXTERNAL_PORT} — то, что брокер отдаёт в metadata.
KAFKA_EXTERNAL_PORT=9092
# deploy/services (stage3 в Docker): host.docker.internal. Только процессы на хосте без Docker — localhost.
KAFKA_EXTERNAL_HOST=host.docker.internal

# INTERNAL: слушает ${KAFKA_INTERNAL_PORT} внутри контейнера; inter-broker и клиенты в app-network (kafka-ui, опционально stage3).
# ADVERTISED INTERNAL://${KAFKA_INTERNAL_HOST}:${KAFKA_INTERNAL_PORT}. Bootstrap для контейнеров в той же сети: kafka:9093
KAFKA_INTERNAL_PORT=9093
KAFKA_INTERNAL_HOST=kafka

# Kafka UI
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_CONTAINER_NAME=kafka-ui
KAFKA_UI_PORT=8080
KAFKA_UI_USERNAME=admin
KAFKA_UI_PASSWORD=admin123
