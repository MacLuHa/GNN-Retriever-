OPENWEBUI_PORT=3000
OPENWEBUI_PIPELINES_PORT=9099
OPENWEBUI_PIPELINES_API_KEY=pipelines-local-key
RETRIEVER_API_PORT=8010
RETRIEVER_API_URL=http://stage7-3-retriever-api:8010
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Kafka: bootstrap и advertised EXTERNAL должны совпадать. В deploy/infrastructure задайте KAFKA_EXTERNAL_HOST=host.docker.internal
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_CHUNKS_TOPIC=documents.chunks
KAFKA_VECTORIZE_TOPIC=documents.vectorize
KAFKA_GRAPH_TOPIC=documents.graph
KAFKA_GRAPH_OUTPUT_TOPIC=documents.graph.entities
KAFKA_GRAPH_DLQ_TOPIC=documents.graph-dlq

# Elasticsearch (stage3-1 indexing, stage3-3 graph, stage7 BM25). Порт должен совпадать с ES_PORT в deploy/infrastructure/.env
ELASTICSEARCH_URL=http://host.docker.internal:9200
ELASTICSEARCH_INDEX=legal_chunks
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=legal_chunks_vectors
QDRANT_DISTANCE=Cosine
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Graph stage service settings
OLLAMA_LLM_MODEL=qwen3:14b
OLLAMA_LLM_TIMEOUT_SEC=120
OLLAMA_LLM_MAX_ATTEMPTS=3
GRAPH_EXTRACTION_MODE=llm_only
GRAPH_RELATION_ENTITY_LIMIT=64
GRAPH_EXTRACTION_DIAGNOSTICS=true
GRAPH_ENTITY_QUALITY_FILTER=true
GRAPH_MAX_ENTITIES_PER_CHUNK=24
GRAPH_GENERIC_ENTITY_STOPWORDS=state,system,group,people,society,government,movement,religion,empire,law
NER_MODEL_NAME=urchade/gliner_large-v2.1
NER_DEVICE=-1
NER_MIN_SCORE=0.65
NER_MAX_ENTITIES=64
NER_ALLOWED_GROUPS=person,organization,location,event,law,movement,ideology,concept,technical_term,book,publication,work_of_art
ENTITY_LEMMATIZE_LANG=en
ENTITY_LEMMATIZE_SCOPE=single
ENTITY_QDRANT_COLLECTION=legal_entities_vectors

OLLAMA_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SEC=30
OLLAMA_MAX_ATTEMPTS=3
EMBEDDING_DIM=256

RETRIEVER_TOP_K=5
BM25_TOP_K=30
GNN_TOP_K=30
BM25_WEIGHT=0.5
GNN_WEIGHT=0.5
MIN_SCORE_THRESHOLD=0.0

GNN_MODEL_PATH=stage7_1_retriever/gnn_weights.json
GNN_HOPS=2
GNN_BATCH_SIZE=64
GNN_USE_NEO4J_EMBEDDINGS=false
GNN_NEO4J_VECTOR_INDEX=chunk_gnn_embedding
LOG_LEVEL=INFO

RETRIEVER_RETRIEVE_TIMEOUT_SEC=20
RETRIEVER_MAX_CONTEXT_CHARS=1200
RETRIEVER_API_LOG_LEVEL=INFO
RETRIEVER_TIMEOUT_SEC=10
RETRIEVER_MAX_CONTEXT_CHUNKS=5

RERANK_ENABLED=false
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANK_TOP_N=30
RERANK_BATCH_SIZE=8
RERANK_TIMEOUT_SEC=15
RERANK_MAX_LENGTH=512
RERANK_DEVICE=auto

# Langfuse tracing (openwebui-pipelines)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://host.docker.internal:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Объём текста в input/output спанов retriever_pipeline (символы)
LANGFUSE_PIPELINE_MAX_STRING=20000
LANGFUSE_PIPELINE_MAX_MESSAGE_CHARS=8000
LANGFUSE_PIPELINE_MAX_MESSAGES=40
