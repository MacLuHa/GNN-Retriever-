# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GRAPH_TOPIC=documents.graph
KAFKA_GRAPH_OUTPUT_TOPIC=documents.graph.entities
KAFKA_GRAPH_DLQ_TOPIC=documents.graph-dlq
KAFKA_CONSUMER_GROUP=graph-knowledge-base
KAFKA_AUTO_OFFSET_RESET=earliest

# Elasticsearch (текст чанка по es_doc_id)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=legal_chunks

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Ollama — чат-модель для извлечения сущностей
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:14b
OLLAMA_LLM_TIMEOUT_SEC=120
OLLAMA_LLM_MAX_ATTEMPTS=3
# Опционально: лимит токенов ответа (Ollama options.num_predict), например 4096 для длинного JSON
# OLLAMA_LLM_NUM_PREDICT=4096

# Нормализация имён сущностей (simplemma): язык ISO 639-1; пусто = без лемматизации
ENTITY_LEMMATIZE_LANG=en
# single = лемматизация только однословных имён; all = каждый токен (осторожно с именами собственными)
ENTITY_LEMMATIZE_SCOPE=single

LOG_LEVEL=INFO
