# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GRAPH_TOPIC=documents.graph
KAFKA_GRAPH_OUTPUT_TOPIC=documents.graph.entities
KAFKA_GRAPH_DLQ_TOPIC=documents.graph-dlq
KAFKA_CONSUMER_GROUP=graph-knowledge-base
KAFKA_AUTO_OFFSET_RESET=earliest

# Elasticsearch (текст чанка по es_doc_id)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=legal_chunks

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Ollama — чат-модель для извлечения сущностей
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:14b
OLLAMA_LLM_TIMEOUT_SEC=120
OLLAMA_LLM_MAX_ATTEMPTS=3
# Опционально: лимит токенов ответа (Ollama options.num_predict), например 4096 для длинного JSON
# OLLAMA_LLM_NUM_PREDICT=4096

# Режим extraction: llm_only | ner_assisted | ner_only
GRAPH_EXTRACTION_MODE=llm_only
# Сколько candidate entities максимум передавать в constrained relation prompt
GRAPH_RELATION_ENTITY_LIMIT=64
# Логировать диагностику extraction по чанкам
GRAPH_EXTRACTION_DIAGNOSTICS=true
# Включить post-filter для шумных сущностей в llm_only / final extraction result
GRAPH_ENTITY_QUALITY_FILTER=true
# Мягкий лимит числа сущностей на chunk после quality-filter
GRAPH_MAX_ENTITIES_PER_CHUNK=24
# Общие однословные сущности, которые отбрасываются, если не relation-backed
GRAPH_GENERIC_ENTITY_STOPWORDS=state,system,group,people,society,government,movement,religion,empire,law

# NER-пилот: извлечение candidate entities вторым мнением
NER_MODEL_NAME=urchade/gliner_large-v2.1
# -1 = CPU, 0/1/... = CUDA device index
NER_DEVICE=-1
NER_MIN_SCORE=0.65
NER_MAX_ENTITIES=64
NER_ALLOWED_GROUPS=person,organization,location,event,law,movement,ideology,concept,technical_term,book,publication,work_of_art

# Нормализация имён сущностей (simplemma): язык ISO 639-1; пусто = без лемматизации
ENTITY_LEMMATIZE_LANG=en
# single = лемматизация только однословных имён; all = каждый токен (осторожно с именами собственными)
ENTITY_LEMMATIZE_SCOPE=single

LOG_LEVEL=INFO
